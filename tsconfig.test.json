{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "test/**/*.ts",
    "test/**/*.svelte",
    "src/**/*.test.ts",
    "src/**/*.test.svelte",
    "src/**/*.test.svelte.ts",
    "src/**/*.spec.ts",
    "src/**/*.spec.svelte",
    "demo/**/*.test.ts",
    "demo/**/*.test.svelte",
    "demo/**/*.test.svelte.ts",
    "demo/**/*.spec.ts",
    "demo/**/*.spec.svelte"
  ]
}
