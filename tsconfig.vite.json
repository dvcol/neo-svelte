{
  "extends": ["@tsconfig/node24/tsconfig.json", "./tsconfig.build.json"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest"]
  },
  "include": [
    "vite.config.ts",
    "svelte.config.js",
    "eslint.config.js",
    "*.config.ts",
    "*.config.js",
    "*.config.mjs",
    "*.config.cjs",
    "env.d.ts",
    ".eslintrc.cjs",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".svelte-kit"
  ]
}
